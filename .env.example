# Application
APP_NAME=AI Clip App
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# API
API_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./data/aiclip.db

# Storage
DATA_DIR=./data
STATIC_DIR=./static
ASSETS_DIR=./static/assets

# AI Provider (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Pipeline / Processing
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
WHISPER_MODEL=base
MAX_UPLOAD_SIZE_MB=1024

# Worker / Jobs
JOB_CONCURRENCY=2
JOB_POLL_INTERVAL_SECONDS=2

# Security
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
