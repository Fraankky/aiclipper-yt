# Application
APP_NAME=AI Clip App
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# API
API_PREFIX=/api/v1

# Storage
DATA_DIR=./data

# ── LLM Providers (set at least one) ─────────────────────────────────
# Priority: OpenRouter → Anthropic → OpenAI → Ollama (local)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_MODEL=llama3.1

# ── Whisper / Transcription ──────────────────────────────────────────
WHISPER_MODEL=turbo
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_BATCH_SIZE=16
WHISPER_LANGUAGE=id

# ── Pipeline ─────────────────────────────────────────────────────────
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
DEFAULT_MIN_DURATION=15
DEFAULT_MAX_DURATION=180
DEFAULT_MAX_CLIPS=72
DEFAULT_MIN_SCORE=55
